{
    "name": "out-performance-k6",
    "version": "1.0.0",
    "description": "Projeto de testes de Performance e Stress",
    "scripts": {
        "build": "webpack",
        "test": "npm run test-smoke",
        "test-smoke": "cross-env K6_TEST_TYPE=smoke npm run test:k6",
        "test-load": "cross-env K6_TEST_TYPE=load npm run test:k6",
        "test-spike": "cross-env K6_TEST_TYPE=spike npm run test:k6",
        "test-soak": "cross-env K6_TEST_TYPE=soak npm run test:k6",
        "test:k6": "webpack && mkdir -p src/reports && cross-env K6_WEB_DASHBOARD=true k6 run dist/exemplo-test.js --summary-export=src/reports/summary-${K6_TEST_TYPE:-smoke}.json",
        "lint": "npx eslint . --ext .ts",
        "lint:fix": "npx eslint . --ext .ts --fix"
       
        
    },
    "repository": {
        "type": "git"
    },
    "keywords": [],
    "author": "warnner",
    "license": "ISC",
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@commitlint/types": "^19.8.1",
        "@babel/core": "7.23.5",
        "@babel/plugin-proposal-class-properties": "7.18.6",
        "@babel/plugin-proposal-object-rest-spread": "7.20.7",
        "@babel/preset-env": "7.23.5",
        "@babel/preset-typescript": "7.23.3",
        "@faker-js/faker": "^8.3.1",
        "@types/k6": "^0.54.1",
        "@types/webpack": "5.28.5",
        "@typescript-eslint/eslint-plugin": "^6.13.2",
        "@typescript-eslint/parser": "^6.13.2",
        "babel-loader": "^9.1.2",
        "clean-webpack-plugin": "4.0.0",
        "copy-webpack-plugin": "^11.0.0",
        "cross-env": "^7.0.3",
        "eslint": "^8.31.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-import-resolver-typescript": "4.3.2",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-prettier": "^5.0.1",
        "eslint-plugin-promise": "^6.1.1",
        "eslint-plugin-sort-class-members": "^1.16.0",
        "eslint-plugin-sort-imports-es6-autofix": "^0.6.0",
        "eslint-plugin-sonarjs": "^0.23.0",
        "eslint-plugin-you-dont-need-lodash-underscore": "^6.12.0",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "json-loader": "^0.5.7",
        "k6": "^0.0.0",
        "prettier": "3.1.0",
        "typescript": "^5.1.6",
        "webpack": "^5.88.1",
        "webpack-cli": "5.1.4",
        "webpack-glob-entries": "^1.0.1"
    },
    "dependencies": {
        "async-request": "^1.0.0",
        "dotenv": "^16.0.3",
        "faker-br": "^0.4.1"
    }
}
